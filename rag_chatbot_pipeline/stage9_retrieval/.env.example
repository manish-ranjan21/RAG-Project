# =====================================================================
# Stage 9 Retrieval Service - Environment Configuration
# Copy this to `.env` and fill in your values.
# =====================================================================

# Environment: 'development', 'staging', 'production'
ENVIRONMENT=development

# ---------------------------------------------------------------------
# Database (your local pgvector instance)
# ---------------------------------------------------------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=ragchatbot
PGUSER=ragchatbot_loader
PGPASSWORD=your_password_here
PGSSLMODE=prefer

# Connection pool sizing
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_STATEMENT_TIMEOUT_MS=5000

# ---------------------------------------------------------------------
# Embeddings (must match what Stage 7 used)
# ---------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_MODEL_VERSION=v3
EMBEDDING_DIMENSION=3072
OPENAI_API_KEY=sk-...
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3
EMBEDDING_COST_PER_1K=0.00013

# ---------------------------------------------------------------------
# Cache
# ---------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_MAX_ENTRIES=1000
CACHE_TTL_SECONDS=3600

# ---------------------------------------------------------------------
# Retrieval tuning
# ---------------------------------------------------------------------
RETRIEVAL_DEFAULT_K=5
RETRIEVAL_MAX_K=50
RETRIEVAL_RERANK_CANDIDATES=20
RETRIEVAL_HNSW_EF=60
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_KEYWORD_WEIGHT=0.3
# Default search mode for end-user queries: 'hybrid' degrades gracefully to
# vector (no keyword match) or boosts keyword hits - no per-query mode picking.
RETRIEVAL_DEFAULT_MODE=hybrid
MIN_SIMILARITY_THRESHOLD=0.0

# ---------------------------------------------------------------------
# Reranking (retrieve-broad-then-rerank for precision)
# ---------------------------------------------------------------------
# Cross-encoder reads (query, chunk) together; far better than embedding
# proximity at filtering keyword-dense-but-irrelevant chunks.
# provider: 'cross_encoder' (local, offline) | 'heuristic' (lexical, no deps)
ENABLE_RERANK=true
RERANK_PROVIDER=cross_encoder
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=text
METRICS_FILE=logs/retrieval_metrics.jsonl
QUERY_LOG_FILE=logs/query_log.jsonl
