# Copy this file to .env and adjust values as needed
# .env is gitignored — .env.example is what gets committed

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBED_MODEL=nomic-embed-text

# Retrieval
RETRIEVAL_K=3
RELEVANCE_THRESHOLD=0.65

# Chunking
CHUNK_SIZE=750
CHUNK_OVERLAP=100

# Paths (relative to src/)
DOCS_FOLDER=docs
DB_PATH=data/chroma
LOG_PATH=data/rag_queries.jsonl
